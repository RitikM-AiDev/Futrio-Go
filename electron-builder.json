{
  "appId": "com.futrio.go",
  "productName": "Futrio Go",

  "directories": {
    "output": "release"
  },

  "files": [
    "dist-electron/**/*",
    "dist-react/**/*",
    "package.json"
  ],

  "icon": "./futrio_go.png",

  "win": {
    "target": ["nsis", "portable"],
    "icon": "./futrio_go.png"
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },

  "mac": {
    "target": "dmg"
  },

  "linux": {
    "target": "AppImage",
    "category": "Utility"
  }
}